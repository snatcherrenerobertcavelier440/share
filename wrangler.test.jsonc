{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "share-test",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-28",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "MAX_SHARE_SIZE_BYTES": "67108864",
    "MAX_ACTIVE_BYTES": "1073741824",
    "MAX_CREATES_PER_HOUR": "5",
    "PENDING_TTL_SECONDS": "3600",
    "READY_TTL_SECONDS": "86400",
    "DOWNLOAD_MULTIPLIER": "4",
    "TURNSTILE_SITE_KEY": "1x00000000000000000000AA",
    "TURNSTILE_SECRET_KEY": "1x0000000000000000000000000000000AA"
  },
  "durable_objects": {
    "bindings": [
      { "name": "SHARES", "class_name": "ShareSession" },
      { "name": "QUOTA", "class_name": "DemoQuota" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["ShareSession", "DemoQuota"] }
  ],
  "r2_buckets": [
    { "binding": "FILES", "bucket_name": "share-test-files" }
  ]
}
